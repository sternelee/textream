    "Refresh Models": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新模型"
          }
        }
      }
    },
    "The mode you pick here becomes the default the next time you open Textream.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您在此处选择的模式将成为下次打开 Textream 时的默认模式。"
          }
        }
      }
    },
    "Voice-Activated uses live microphone levels. Word Tracking uses the speech locale selected here when starting recognition.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音激活模式使用实时麦克风音量。跟词模式在开始识别时使用此处选择的语音区域设置。"
          }
        }
      }
    },
    "Tap to briefly listen through the microphone and verify audio levels respond to your voice.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按以短暂通过麦克风收听，验证音频电平是否响应您的声音。"
          }
        }
      }
    },
    "Prevent the device from auto-locking while reading.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读期间防止设备自动锁定。"
          }
        }
      }
    },
    "Long-press any word in Reader to see phonetic transcription and translation.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读器中长按任意单词，即可查看音标和翻译。"
          }
        }
      }
    },
    "Copy your current reader settings as JSON to share between devices, or paste a previously exported settings JSON.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将当前阅读器设置复制为 JSON 以在设备间共享，或粘贴之前导出的设置 JSON。"
          }
        }
      }
    },
    "Add your OpenAI API key to enable AI script generation. Your key is stored locally on this device. Compatible with OpenAI API and any OpenAI-compatible endpoint.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加 OpenAI API 密钥以启用 AI 脚本生成。密钥仅存储在本设备上，兼容 OpenAI API 及任何 OpenAI 兼容端点。"
          }
        }
      }
    },
    "Local draft state is restored when the app returns.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用返回前台时将恢复本地草稿状态。"
          }
        }
      }
    },
    "Reader pauses microphone-based modes when the app moves to the background.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用进入后台时，阅读器将暂停基于麦克风的模式。"
          }
        }
      }
    },
    "Built-in test scripts match the device checklist so you can validate flows faster.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置测试脚本与设备检查清单匹配，帮助您更快验证流程。"
          }
        }
      }
    },
    "Reset font, size, highlight color, scroll speed, speech locale, and reading mode to factory defaults.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将字体、大小、高亮颜色、滚动速度、语音区域和阅读模式重置为出厂默认值。"
          }
        }
      }
    },
    "Your selected font, size, and highlight color will be used in Reader mode.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您选择的字体、大小和高亮颜色将在阅读器模式中使用。"
          }
        }
      }
    },
    "Tap any word in Reader to jump to it.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读器中点按任意单词可跳转到该位置。"
          }
        }
      }
    },
    "Double-tap the reading area to pause or resume.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "双击阅读区域可暂停或恢复。"
          }
        }
      }
    },
    "Shake your device in Reader to pause or resume.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读器中摇动设备可暂停或恢复。"
          }
        }
      }
    },
    "Swipe left or right in Reader to change pages.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读器中左右滑动可翻页。"
          }
        }
      }
    },
    "Pinch to zoom in Reader to adjust font size.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读器中捏合缩放可调整字体大小。"
          }
        }
      }
    },
    "Use keyboard shortcuts: Space = Pause, ←/→ = Pages, Home/End = Jump.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用键盘快捷键：空格 = 暂停，←/→ = 翻页，Home/End = 跳转。"
          }
        }
      }
    },
    "API Key (sk-...)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API 密钥 (sk-...)"
          }
        }
      }
    },
    "Settings copied to clipboard.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置已复制到剪贴板。"
          }
        }
      }
    },
    "Failed to export settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出设置失败。"
          }
        }
      }
    },
    "Clipboard is empty.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板为空。"
          }
        }
      }
    },
    "Invalid clipboard content.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无效的剪贴板内容。"
          }
        }
      }
    },
    "Imported settings successfully.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置已成功导入。"
          }
        }
      }
    },
    "Fetched %lld models.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已获取 %lld 个模型。"
          }
        }
      }
    },
    "Restored your last local draft.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已恢复上次的本地草稿。"
          }
        }
      }
    },
    "Restored your last open script and local edits.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已恢复上次打开的脚本及本地编辑。"
          }
        }
      }
    }
  },
  "version": "1.0"
